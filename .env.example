# ============================================================
# Nepali Word Game — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# ----- Node Environment -----
NODE_ENV=development
PORT=3000

# ----- Database -----
DB_HOST=mysql
DB_PORT=3306
DB_ROOT_PASSWORD=changeme_root
DB_NAME=nepali_word_game
DB_USER=nwg_user
DB_PASSWORD=changeme_nwg

# ----- JWT -----
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=your_very_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ----- CORS -----
# In production, set this to your actual domain:
# CORS_ORIGIN=https://yourdomain.com
CORS_ORIGIN=*

# ----- Email (Gmail SMTP) -----
# 1. Enable 2-Step Verification on your Google account
# 2. Go to: myaccount.google.com → Security → App passwords
# 3. Generate an app password for "Mail"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_16_char_app_password

# ----- Frontend URL -----
# Used for email verification links
# In production, set this to your actual domain:
FRONTEND_URL=http://localhost:8888
